# ── LLM 解读层（命理+心理 双声部）—— provider 无关，双线协议 ──
# 切换模型只需改这几个环境变量，无需改代码。

# 默认：MiniMax-M3 Coding/Token Plan（Anthropic 兼容线协议）
LLM_PROVIDER=minimax              # minimax | deepseek | openai-compatible | anthropic-compatible
LLM_MODEL=MiniMax-M3
# base 预设已含默认值，可省略；MiniMax 默认 https://api.minimax.io/anthropic（中国区改 api.minimaxi.com/anthropic）
# LLM_BASE_URL=https://api.minimax.io/anthropic
LLM_API_KEY=                      # ⚠️ MiniMax Coding/Token Plan 订阅 key（sk-cp…），platform.minimax.io 获取
# 也兼容生态既有变量：ANTHROPIC_AUTH_TOKEN / ANTHROPIC_BASE_URL（anthropic 线协议时自动读取）

# 备选 provider 示例（OpenAI 兼容线协议）：
# LLM_PROVIDER=deepseek  LLM_MODEL=deepseek-chat  LLM_API_KEY=...
# 任意端点：LLM_PROVIDER=openai-compatible  LLM_WIRE=openai  LLM_BASE_URL=https://.../v1  LLM_MODEL=xxx  LLM_API_KEY=...

# ── 紫微安星法 ──
ZIWEI_ALGORITHM=zhongzhou         # default | zhongzhou

# ── Supabase（档案存储，匿名登录 + RLS）──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx   # 可公开的 publishable key（非 service_role）
